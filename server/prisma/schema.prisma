generator client {
  provider = "prisma-client"
  output   = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
}

model Technology {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  website     String?
  category    Category
  ring        Ring
  moved       Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum Category {
  TECHNIQUES
  PLATFORMS
  TOOLS
  LANGUAGES_AND_FRAMEWORKS
}

enum Ring {
  ADOPT
  TRIAL
  ASSESS
  HOLD
}
